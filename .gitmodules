[submodule "external/rocknix/rocknix-joypad"]
	path = external/rocknix/rocknix-joypad
	url = https://github.com/ROCKNIX/rocknix-joypad.git
[submodule "external/rocknix/mali_kbase"]
	path = external/rocknix/mali_kbase
	url = https://github.com/ROCKNIX/mali_kbase.git
[submodule "external/linux"]
	path = external/boot/linux
	url = https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git
	tag = v6.18.9
[submodule "external/u-boot"]
	path = external/boot/u-boot
	url = https://github.com/u-boot/u-boot.git
[submodule "external/rkbin"]
	path = external/boot/rkbin
	url = https://github.com/rockchip-linux/rkbin.git
[submodule "external/tools/busybox"]
	path = external/tools/busybox
	url = https://github.com/mirror/busybox.git
[submodule "external/tools/exfatprogs"]
	path = external/tools/exfatprogs
	url = https://github.com/exfatprogs/exfatprogs.git
[submodule "external/tools/SDL2"]
	path = external/tools/SDL2
	url = https://github.com/libsdl-org/SDL.git
	branch = SDL2
[submodule "external/tools/SDL2_image"]
	path = external/tools/SDL2_image
	url = https://github.com/libsdl-org/SDL_image.git
	branch = SDL2
[submodule "external/tools/gptfdisk"]
	path = external/tools/gptfdisk
	url = https://github.com/samangh/gptfdisk.git
[submodule "external/tools/alsa-utils"]
	path = external/tools/alsa-utils
	url = https://github.com/alsa-project/alsa-utils.git
[submodule "external/retroarch/frontend"]
	path = external/retroarch/frontend
	url = https://github.com/libretro/RetroArch.git
[submodule "external/retroarch/mupen64plus-libretro-nx"]
	path = external/retroarch/mupen64plus-libretro-nx
	url = https://github.com/libretro/mupen64plus-libretro-nx.git
[submodule "external/retroarch/flycast"]
	path = external/retroarch/flycast
	url = https://github.com/flyinghead/flycast.git
[submodule "external/retroarch/pcsx-rearmed"]
	path = external/retroarch/pcsx-rearmed
	url = https://github.com/libretro/pcsx_rearmed.git
[submodule "external/retroarch/ppsspp"]
	path = external/retroarch/ppsspp
	url = https://github.com/hrydgard/ppsspp.git
